---
import '../styles/global.css';
import { BeamsBackground } from '../components/ui/beams-background';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Inference Innovation — Industrial Transformation to 2030',
  description = 'Applied AI and human amplification for construction, manufacturing, and heavy industry. Frascati-compliant R&D&I programs that resolve the half-century productivity stall.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://www.inferenceinnovation.ai').toString();

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Inference Innovation',
  url: 'https://www.inferenceinnovation.ai',
  description,
  sameAs: ['https://www.linkedin.com/'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#08090c" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://prod.spline.design" />
    <link rel="dns-prefetch" href="https://prod.spline.design" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Inference Innovation" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="format-detection" content="telephone=no" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    <!-- Must run before first paint so the browser never restores a saved scroll position -->
    <script is:inline>
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }
      window.scrollTo({ top: 0, behavior: 'instant' });
      // Second enforcement at load — browser scroll restoration can override the head-time call
      window.addEventListener('load', function() {
        window.scrollTo({ top: 0, behavior: 'instant' });
      }, { once: true });
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <BeamsBackground client:load intensity="subtle" fixed={true} />
    <slot />

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-in');
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.1, rootMargin: '0px 0px -4% 0px' }
      );

      // Progressive enhancement: elements are visible by default (CSS has no opacity:0).
      // Only below-fold elements get .scroll-animate, which hides them and arms the transition.
      // In-viewport elements (hero, etc.) are left untouched and appear instantly.
      document.querySelectorAll('.reveal, .reveal-up, .word-reveal').forEach((el) => {
        const rect = el.getBoundingClientRect();
        // Use document-relative position so this is correct even if the browser
        // restores scroll before this script runs (rect is viewport-relative).
        const docTop = rect.top + window.scrollY;
        const docBottom = rect.bottom + window.scrollY;
        const inViewport = docTop < window.innerHeight && docBottom > 0;
        if (!inViewport) {
          el.classList.add('scroll-animate');
          if (el.classList.contains('word-reveal')) {
            el.querySelectorAll(':scope > span').forEach((s, i) => {
              (s as HTMLElement).style.transitionDelay = `${i * 50}ms`;
            });
          }
          io.observe(el);
        }
      });

      document.querySelectorAll<HTMLElement>('[data-countup]').forEach((el) => {
        const target = parseFloat(el.dataset.countup || '0');
        const suffix = el.dataset.suffix || '';
        const decimals = parseInt(el.dataset.decimals || '0', 10);
        const ob = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              const start = performance.now();
              const dur = 900;
              const tick = (now: number) => {
                const t = Math.min(1, (now - start) / dur);
                const eased = 1 - Math.pow(1 - t, 3);
                const v = (target * eased).toFixed(decimals);
                el.textContent = v + suffix;
                if (t < 1) requestAnimationFrame(tick);
              };
              if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
                el.textContent = target.toFixed(decimals) + suffix;
              } else {
                requestAnimationFrame(tick);
              }
              ob.unobserve(el);
            }
          },
          { threshold: 0.6 }
        );
        ob.observe(el);
      });

      // ── Active nav section ───────────────────────────────────────────────
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const navAnchors = document.querySelectorAll<HTMLAnchorElement>('nav a[href^="#"]');
        const sectionIds = ['challenge','framework','network','programs','team','engage'];
        const navSectionObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              navAnchors.forEach((a) => {
                a.classList.toggle('nav-active', a.getAttribute('href') === '#' + id);
              });
            }
          });
        }, { threshold: 0.25, rootMargin: '-5% 0px -60% 0px' });
        sectionIds.forEach((id) => {
          const el = document.getElementById(id);
          if (el) navSectionObserver.observe(el);
        });
      }

      // ── Card highlight on hover (adds .card-highlighted class) ─────────
      document.querySelectorAll<HTMLElement>('.signal-glow').forEach((card) => {
        card.addEventListener('mouseenter', () => card.classList.add('card-highlighted'));
        card.addEventListener('mouseleave', () => card.classList.remove('card-highlighted'));
      });
    </script>
  </body>
</html>
