---
const units = [
  {
    code: 'U/01',
    name: 'Applied Engineering Pod',
    role: 'The Builders',
    roles: ['Senior ML-Ops Engineers', 'Agentic Systems Architects', 'Full-Stack Industrial Developers', 'Vector Database Administrators'],
  },
  {
    code: 'U/02',
    name: 'Domain Bridge',
    role: 'The Translators',
    roles: ['BIM Integration Specialists', 'Digital Twin Structural Engineers', 'Process Mining Analysts', 'Site Context Mappers'],
    note: 'Civil and mechanical engineers re-trained in data science.',
  },
  {
    code: 'U/03',
    name: 'Frascati Compliance Cell',
    role: 'The Auditors',
    roles: ['Technical R&D Authors', 'Innovation Data Controllers', 'Regulatory Analysts'],
  },
  {
    code: 'U/04',
    name: 'Data Sovereignty Unit',
    role: 'The Protectors',
    roles: ['Data Lineage Officers', 'Security Architecture Leads', 'IP Governance Officers'],
  },
];

const advantages = [
  ['Scale without bloat', '~30 specialists. No partner-pyramid overhead.'],
  ['Follow-the-sun delivery', 'Time-zone hand-offs across European, American, and APAC windows.'],
  ['AI-native by demonstration', 'We use the systems we build — internally, every day.'],
  ['Engineering-first credibility', 'Domain credentials before model credentials.'],
];
---
<section id="network" class="relative py-28 sm:py-36 border-t border-[var(--color-rule)]">
  <div class="container-page">
    <div class="section-grid">
      <aside class="rail mb-4 lg:mb-0 reveal">
        <div class="section-num float-y">§&nbsp;03</div>
        <div class="hidden lg:block w-px h-12 bg-[var(--color-rule-strong)] mt-3 ml-[0.45rem]" aria-hidden="true"></div>
      </aside>

      <header class="body reveal">
        <div class="eyebrow">The Distributed Network</div>
        <h2 class="mt-5 text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.02] max-w-[22ch]">
          Four units, one <em class="text-[var(--color-signal)]">inference</em> spine.
        </h2>
        <p class="mt-8 text-[var(--color-paper)]/85 text-[1.0625rem] leading-[1.7] max-w-[62ch]">
          A remote-first network, organised around the cycle of a decision rather than the seats in a building. Every unit has authority where it has expertise — and a clean handoff at the boundary.
        </p>
      </header>

      <aside class="margin hidden lg:block reveal mt-1">
        <div class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-[var(--color-rule-strong)]">— Topology —</div>
        <p class="mt-3 font-mono text-[0.74rem] uppercase tracking-[0.16em] text-[var(--color-mute)] leading-[1.7]">
          Remote-first.<br/>
          Europe primary.<br/>
          APAC onboarding.
        </p>
      </aside>
    </div>

    <ol class="mt-20 grid md:grid-cols-2 gap-px bg-[var(--color-rule)] border border-[var(--color-rule)] scan-line">
      {units.map((u, i) => (
        <li class="bg-[var(--color-ink)] p-8 sm:p-10 reveal corner-tick signal-glow stagger-reveal" style={`--stagger: ${i}`}>
          <div class="flex items-center justify-between">
            <span class="font-mono text-[0.74rem] uppercase tracking-[0.2em] text-[var(--color-signal)]">{u.code}</span>
            <span class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-[var(--color-mute)]">{u.role}</span>
          </div>
          <h3 class="mt-8 text-[1.625rem] sm:text-[1.875rem] leading-[1.06] max-w-[20ch]" style="font-variation-settings: 'opsz' 48, 'wght' 440;">{u.name}</h3>
          <div class="mt-5 rule-tick" aria-hidden="true"></div>
          <ul class="mt-5">
            {u.roles.map((r, i) => (
              <li class="py-2.5 flex items-baseline gap-3 font-mono text-[0.82rem] leading-[1.5] text-[var(--color-paper)]/90">
                <span aria-hidden="true" class="text-[var(--color-signal)] text-[0.7em] mt-0.5">▸</span>
                <span>{r}</span>
              </li>
            ))}
          </ul>
          {u.note && <p class="mt-6 text-[0.875rem] italic text-[var(--color-mute)] max-w-[42ch] font-display leading-[1.5]" style="font-variation-settings: 'opsz' 18, 'wght' 380;">{u.note}</p>}
        </li>
      ))}
    </ol>

    <!-- Autonomous workforce -->
    <div class="mt-24 section-grid">
      <aside class="rail mb-4 lg:mb-0 reveal">
        <div class="section-num text-[var(--color-signal)]">A/§</div>
      </aside>
      <div class="body">
        <div class="grid lg:grid-cols-12 gap-10">
          <header class="lg:col-span-5 reveal">
            <div class="eyebrow signal-eyebrow">Autonomous Digital Workforce</div>
            <h3 class="mt-4 text-[2rem] leading-[1.04] max-w-[18ch]" style="font-variation-settings: 'opsz' 48, 'wght' 440;">
              24<span class="text-[var(--color-signal)]">/</span>7 agents alongside humans.
            </h3>
            <p class="mt-6 text-[0.95rem] text-[var(--color-paper)]/80 leading-[1.65] max-w-[50ch]">
              AI agents shoulder the repetitive layer — ingestion, pattern detection, compliance checks — so that human specialists spend their hours where judgment, not throughput, is the constraint.
            </p>
          </header>
          <ul class="lg:col-span-7 reveal grid sm:grid-cols-2 gap-px bg-[var(--color-rule)] border border-[var(--color-rule)]">
            {advantages.map(([title, body], i) => (
              <li class="bg-[var(--color-ink)] p-6 corner-tick reveal stagger-reveal" style={`--stagger: ${i}`}>
                <div class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-[var(--color-signal)]">A/{String(i + 1).padStart(2, '0')}</div>
                <h4 class="mt-4 text-[1.125rem] font-display leading-[1.2]" style="font-variation-settings: 'opsz' 24, 'wght' 480;">{title}</h4>
                <p class="mt-2 text-[0.85rem] text-[var(--color-mute)] leading-[1.6] font-mono">{body}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
