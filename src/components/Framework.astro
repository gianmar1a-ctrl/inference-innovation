---
const mechanisms = [
  {
    n: '01',
    title: 'Coordination Elimination',
    body: 'Wrap human decision points with computational inference so that uncertainty is resolved before execution begins — not absorbed as rework downstream.',
    tags: ['inference', 'decision-intelligence', 'pre-execution'],
  },
  {
    n: '02',
    title: 'Human Amplification',
    body: 'Skilled operators retain authority. Real-time computational support sits beneath the decision, surfacing context, options, and constraints at the moment they matter.',
    tags: ['expert-in-the-loop', 'context-grounding', 'authority-preserved'],
  },
  {
    n: '03',
    title: 'Manufacturing-Grade Certainty',
    body: 'Project-based delivery becomes process discipline. Variance falls. Outcomes are auditable. Programs ship to the same predictability bar as the production line itself.',
    tags: ['process-discipline', 'audit-defensible', 'low-variance'],
  },
];
---
<section id="framework" class="relative py-28 sm:py-36 border-t border-[var(--color-rule)]">
  <div class="container-page">
    <div class="section-grid">
      <aside class="rail mb-4 lg:mb-0 reveal">
        <div class="section-num float-y">§&nbsp;02</div>
        <div class="hidden lg:block w-px h-12 bg-[var(--color-rule-strong)] mt-3 ml-[0.45rem]" aria-hidden="true"></div>
      </aside>

      <header class="body reveal">
        <div class="eyebrow">The Framework</div>
        <h2 class="mt-5 text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.02] max-w-[20ch]">
          The <em class="text-[var(--color-signal)]">Post-Baumol</em> mechanism.
        </h2>
        <p class="mt-8 text-[var(--color-paper)]/85 text-[1.0625rem] leading-[1.7] max-w-[62ch]">
          Three coordinated mechanisms, deployed together. The point is not to add intelligence on top of existing workflow — it is to remove the coordination loss that conventional methods cannot reach.
        </p>
      </header>

      <aside class="margin hidden lg:block reveal mt-1">
        <div class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-[var(--color-rule-strong)]">— Mechanisms —</div>
        <p class="mt-3 font-mono text-[0.74rem] uppercase tracking-[0.16em] text-[var(--color-mute)] leading-[1.7]">
          M/01 → M/02 → M/03<br/>
          deployed as one
        </p>
      </aside>
    </div>

    <ol class="mt-20 grid lg:grid-cols-3 gap-px bg-[var(--color-rule)] border border-[var(--color-rule)] scan-line">
      {mechanisms.map((m, i) => (
        <li class="bg-[var(--color-ink)] p-8 sm:p-10 flex flex-col reveal corner-tick signal-glow stagger-reveal" style={`--stagger: ${i}`}>
          <div class="flex items-center justify-between">
            <span class="font-mono text-[0.74rem] uppercase tracking-[0.2em] text-[var(--color-signal)]">M/{m.n}</span>
            <span class="signal-dot float-y" style={`animation-delay: ${i * 0.8}s`} aria-hidden="true"></span>
          </div>
          <h3 class="mt-10 text-[1.75rem] leading-[1.08] max-w-[16ch]" style="font-variation-settings: 'opsz' 48, 'wght' 440;">{m.title}</h3>
          <div class="mt-5 rule-tick" aria-hidden="true"></div>
          <p class="mt-5 text-[var(--color-paper)]/80 text-[0.95rem] leading-[1.7] max-w-[42ch]">{m.body}</p>
          <div class="mt-auto pt-10 flex flex-wrap gap-x-3 gap-y-1 font-mono text-[0.66rem] uppercase tracking-[0.14em] text-[var(--color-mute)]">
            {m.tags.map((t, i) => (
              <span>
                {i > 0 && <span class="text-[var(--color-rule-strong)] mr-2.5">·</span>}
                {t}
              </span>
            ))}
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
