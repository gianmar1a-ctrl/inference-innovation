---
const compliance = [
  'Scientific rigor in experimental development',
  'Documented resolution of technical uncertainty',
  'Verified innovation outcomes',
  'Audit-defensible research processes',
];

const commitments = [
  'Frascati-compliant innovation programs',
  'Verified productivity transformation, measurably documented',
  'IP assets and core-competence build-out',
  'Multi-jurisdiction R&D-incentive optimisation',
];
---
<section id="programs" class="relative py-28 sm:py-36 border-t border-[var(--color-rule)]">
  <div class="container-page">
    <div class="section-grid">
      <aside class="rail mb-4 lg:mb-0 reveal">
        <div class="section-num float-y">§&nbsp;04</div>
        <div class="hidden lg:block w-px h-12 bg-[var(--color-rule-strong)] mt-3 ml-[0.45rem]" aria-hidden="true"></div>
      </aside>

      <header class="body reveal">
        <div class="eyebrow">Applied AI Programs</div>
        <h2 class="mt-5 text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.02] max-w-[16ch]">
          Outcomes, not <em class="text-[var(--color-signal)]">hours.</em>
        </h2>
        <p class="mt-8 text-[var(--color-paper)]/85 text-[1.0625rem] leading-[1.7] max-w-[62ch]">
          Programs run on Frascati and Oslo Manual rails. Every claim is documented, every uncertainty resolution recorded, every outcome verifiable — the standard regulators expect, applied as engineering discipline.
        </p>
      </header>

      <aside class="margin hidden lg:block reveal mt-1">
        <div class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-[var(--color-rule-strong)]">— Manuals —</div>
        <p class="mt-3 font-mono text-[0.74rem] uppercase tracking-[0.16em] text-[var(--color-mute)] leading-[1.7]">
          OECD Frascati<br/>
          (2015 ed.)<br/>
          OECD/Eurostat Oslo<br/>
          (4th ed.)
        </p>
      </aside>
    </div>

    <div class="mt-20 grid lg:grid-cols-2 gap-px bg-[var(--color-rule)] border border-[var(--color-rule)] scan-line">
      <div class="bg-[var(--color-ink)] p-8 sm:p-10 reveal corner-tick signal-glow">
        <div class="flex items-baseline justify-between">
          <span class="font-mono text-[0.74rem] uppercase tracking-[0.2em] text-[var(--color-signal)]">C / §</span>
          <span class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-[var(--color-mute)]">{compliance.length} items</span>
        </div>
        <h3 class="mt-8 text-[1.625rem] sm:text-[1.875rem] leading-[1.06] max-w-[18ch]" style="font-variation-settings: 'opsz' 48, 'wght' 440;">Frascati &amp; Oslo as the operating manual.</h3>
        <div class="mt-7 rule-tick" aria-hidden="true"></div>
        <ul class="mt-2">
          {compliance.map((c, i) => (
            <li class="flex items-baseline gap-5 py-4 border-b border-[var(--color-rule)] reveal stagger-reveal" style={`--stagger: ${i}`}>
              <span class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-[var(--color-signal)] shrink-0">C/{String(i + 1).padStart(2, '0')}</span>
              <span class="text-[0.95rem] leading-[1.55]">{c}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-[var(--color-ink)] p-8 sm:p-10 reveal corner-tick signal-glow">
        <div class="flex items-baseline justify-between">
          <span class="font-mono text-[0.74rem] uppercase tracking-[0.2em] text-[var(--color-signal)]">O / §</span>
          <span class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-[var(--color-mute)]">{commitments.length} items</span>
        </div>
        <h3 class="mt-8 text-[1.625rem] sm:text-[1.875rem] leading-[1.06] max-w-[18ch]" style="font-variation-settings: 'opsz' 48, 'wght' 440;">Manufacturing-grade deliverables.</h3>
        <div class="mt-7 rule-tick" aria-hidden="true"></div>
        <ul class="mt-2">
          {commitments.map((c, i) => (
            <li class="flex items-baseline gap-5 py-4 border-b border-[var(--color-rule)] reveal stagger-reveal" style={`--stagger: ${i}`}>
              <span class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-[var(--color-signal)] shrink-0">O/{String(i + 1).padStart(2, '0')}</span>
              <span class="text-[0.95rem] leading-[1.55]">{c}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Risk model — stamped callout -->
    <aside class="mt-12 reveal corner-tick gradient-border border border-[var(--color-signal)]/50 bg-[color-mix(in_oklab,var(--color-signal)_5%,transparent)] p-8 sm:p-12">
      <div class="flex items-baseline justify-between">
        <span class="font-mono text-[0.74rem] uppercase tracking-[0.2em] text-[var(--color-signal)]">R / Model</span>
        <span class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-[var(--color-signal)]/70">Execution risk: ours</span>
      </div>
      <p class="mt-8 font-display text-[1.625rem] sm:text-[2.25rem] leading-[1.12] max-w-[36ch]" style="font-variation-settings: 'opsz' 96, 'wght' 420;">
        We carry the execution risk. You receive manufacturing-grade outcomes — or we don't invoice.
      </p>
    </aside>
  </div>
</section>
