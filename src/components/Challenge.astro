---
const stats = [
  { v: '3.5', suf: '%', dec: 1, label: 'Manufacturing', context: 'Annual productivity improvement since 1970' },
  { v: '0.4', suf: '%', dec: 1, label: 'Construction', context: 'Annual productivity improvement since 1970' },
  { v: '2', suf: '%', dec: 0, label: 'Heavy Industry', context: 'Maximum annual gains under conventional methods' },
];
const threats = [
  'Competitiveness erosion across advanced economies',
  'Margin compression for builders and manufacturers',
  'Slipping infrastructure and industrial-program timelines',
  'Workforce attrition under coordination overhead',
];
---
<section id="challenge" class="relative py-28 sm:py-36 border-t border-[var(--color-rule)]">
  <div class="container-page">
    <div class="section-grid">
      <aside class="rail mb-4 lg:mb-0 reveal">
        <div class="section-num float-y">§&nbsp;01</div>
        <div class="hidden lg:block w-px h-12 bg-[var(--color-rule-strong)] mt-3 ml-[0.45rem]" aria-hidden="true"></div>
      </aside>

      <header class="body reveal">
        <div class="eyebrow">The Challenge</div>
        <h2 class="mt-5 text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.02] max-w-[18ch]">
          Why industrial productivity <em class="text-[var(--color-signal)]">stopped</em> in 1970.
        </h2>
        <p class="mt-8 text-[var(--color-paper)]/85 text-[1.0625rem] leading-[1.7] max-w-[62ch]">
          Labor-heavy sectors run into a structural ceiling first described by William Baumol: coordination overhead grows faster than the methods used to manage it. Software, automation, and lean programs have repeatedly failed to break the curve because they target tasks, not the inference loop that surrounds them.
        </p>
        <p class="mt-5 text-[var(--color-mute)] text-[0.95rem] leading-[1.6] max-w-[62ch]">
          Three numbers tell the story of the last half-century — and frame the work for the next five years.
        </p>
      </header>

      <aside class="margin hidden lg:block reveal mt-1">
        <div class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-[var(--color-rule-strong)]">— Source —</div>
        <p class="mt-3 italic font-display text-[0.85rem] leading-[1.45] text-[var(--color-paper)]/70" style="font-variation-settings: 'opsz' 18, 'wght' 380;">
          Baumol, W.J. (1967). "Macroeconomics of unbalanced growth: the anatomy of urban crisis."
        </p>
      </aside>
    </div>

    <!-- Stats: three engineering-spec callouts, hairline-bounded -->
    <div class="mt-20 reveal">
      <div class="rule-tick" aria-hidden="true"></div>
      <div class="mt-10 grid sm:grid-cols-3 gap-10 sm:gap-px sm:bg-[var(--color-rule)] sm:border sm:border-[var(--color-rule)] scan-line">
        {stats.map((s, i) => (
          <article class="sm:bg-[var(--color-ink)] p-0 sm:p-8 reveal stagger-reveal" style={`--stagger: ${i}`}>
            <div class="flex items-baseline justify-between">
              <span class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-[var(--color-signal)]">{String(i + 1).padStart(2, '0')} / 03</span>
              <span class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-[var(--color-mute)]">since 1970</span>
            </div>
            <div class="mt-7 font-display text-[clamp(3.25rem,7vw,5rem)] leading-[0.95]" style="font-variation-settings: 'opsz' 144, 'wght' 380;">
              <span data-countup={s.v} data-suffix={s.suf} data-decimals={s.dec}>0{s.suf}</span>
            </div>
            <div class="mt-4 rule-tick" aria-hidden="true"></div>
            <h3 class="mt-5 text-[1.375rem]" style="font-variation-settings: 'opsz' 36, 'wght' 460;">{s.label}</h3>
            <p class="mt-2 font-mono text-[0.78rem] leading-[1.55] text-[var(--color-mute)]">{s.context}</p>
          </article>
        ))}
      </div>
    </div>

    <!-- Threats block — hanging numbers, hairline divides -->
    <div class="mt-24 section-grid">
      <aside class="rail mb-4 lg:mb-0 reveal">
        <div class="section-num text-[var(--color-signal)]">T/§</div>
      </aside>
      <div class="body">
        <div class="grid lg:grid-cols-12 gap-10">
          <header class="lg:col-span-4 reveal">
            <div class="eyebrow signal-eyebrow">Threats to 2030</div>
            <h3 class="mt-4 text-[1.875rem] leading-[1.04] max-w-[18ch]" style="font-variation-settings: 'opsz' 48, 'wght' 440;">
              Where the curve bends — or breaks.
            </h3>
          </header>
          <ul class="lg:col-span-8 reveal">
            <div class="rule-tick" aria-hidden="true"></div>
            {threats.map((t, i) => (
              <li class="flex items-start gap-5 sm:gap-7 py-6 border-b border-[var(--color-rule)]">
                <span class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-[var(--color-signal)] pt-1 shrink-0">T/{String(i + 1).padStart(2, '0')}</span>
                <p class="text-[1.0625rem] leading-[1.55]">{t}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
